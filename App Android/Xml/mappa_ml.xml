<?xml version="1.0" encoding="utf-8"?>

<!-- Layout principale della schermata ML -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- WebView che contiene la mappa ML -->
    <WebView
        android:id="@+id/webViewMappaML"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Contenitore della selezione orizzonte -->
    <LinearLayout
        android:id="@+id/contenitoreOrizzonte"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#CCFFFFFF"
        android:clickable="false"
        android:focusable="false"
        android:elevation="6dp"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Titolo selezione orizzonte -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Orizzonte previsione"
            android:textColor="#000"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Menu selezione orizzonte temporale -->
        <Spinner
            android:id="@+id/selettoreOrizzonte"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>